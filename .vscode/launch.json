{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "CubrainApplication",
      "request": "launch",
      "mainClass": "com.cubrain.springboot_starter_auth.CubrainApplication",
      "projectName": "backend",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "type": "java",
      "name": "CubrainApplication (local)",
      "request": "launch",
      "mainClass": "com.cubrain.springboot_starter_auth.CubrainApplication",
      "projectName": "cubrain",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "SPRING_PROFILES_ACTIVE": "local"
      },
      "args": ""
    },
    {
      "type": "java",
      "name": "CubrainApplication (prod)",
      "request": "launch",
      "mainClass": "com.cubrain.springboot_starter_auth.CubrainApplication",
      "projectName": "cubrain",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "SPRING_PROFILES_ACTIVE": "prod"
      },
      "args": ""
    },
    {
      "type": "java",
      "name": "CubrainApplication (custom env)",
      "request": "launch",
      "mainClass": "com.cubrain.springboot_starter_auth.CubrainApplication",
      "projectName": "cubrain",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "SPRING_PROFILES_ACTIVE": "local"
      },
      "args": ""
    }
  ]
}
